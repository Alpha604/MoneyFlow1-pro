{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "label": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "iconName": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "label", "category", "amount", "date", "type", "createdAt", "updatedAt"]
    },
    "Account": {
      "title": "Account",
      "description": "User bank account or wallet",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "bank": { "type": "string" },
        "balance": { "type": "number" },
        "type": { "type": "string" },
        "color": { "type": "string" },
        "iconName": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "name", "bank", "balance", "type", "createdAt", "updatedAt"]
    },
    "Card": {
      "title": "Card",
      "description": "User credit or debit card",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "network": { "type": "string" },
        "last4": { "type": "string" },
        "expiry": { "type": "string" },
        "type": { "type": "string" },
        "color": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "name", "network", "last4", "expiry", "createdAt", "updatedAt"]
    },
    "Budget": {
      "title": "Budget",
      "description": "User budget goal",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "label": { "type": "string" },
        "total": { "type": "number" },
        "spent": { "type": "number" },
        "color": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "label", "total", "spent", "createdAt", "updatedAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "User financial goal",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "target": { "type": "number" },
        "current": { "type": "number" },
        "date": { "type": "string" },
        "colorGroup": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "name", "target", "current", "date", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Transactions"
    },
    "/accounts/{accountId}": {
      "schema": { "$ref": "#/entities/Account" },
      "description": "Accounts"
    },
    "/cards/{cardId}": {
      "schema": { "$ref": "#/entities/Card" },
      "description": "Cards"
    },
    "/budgets/{budgetId}": {
      "schema": { "$ref": "#/entities/Budget" },
      "description": "Budgets"
    },
    "/goals/{goalId}": {
      "schema": { "$ref": "#/entities/Goal" },
      "description": "Goals"
    }
  }
}
